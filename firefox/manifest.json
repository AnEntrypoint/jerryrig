{
  "manifest_version": 2,
  "name": "Webrig Audio Bridge",
  "version": "1.0.0",
  "description": "Full host mode: tab audio/video relay, CDP passthrough, and input forwarding to Webrig via WebSocket",
  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "debugger",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Webrig Audio Bridge"
  }
}
