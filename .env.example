# Your Discord account token (NOT a bot token — this uses the selfbot API)
# WARNING: Using selfbots violates Discord ToS. Risk of account ban.
# Get this from Discord web client: DevTools > Application > Local Storage > token
BOT_TOKEN=your_discord_user_token_here

# The URL to display in the Electron window
TARGET_URL=https://example.com

# Discord server (guild) ID — right-click server icon > Copy Server ID
GUILD_ID=123456789012345678

# Voice channel ID to join — right-click channel > Copy Channel ID
CHANNEL_ID=123456789012345678

# Video stream settings
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=24
VIDEO_BITRATE=3000

# Chrome DevTools Protocol port for agent-browser (vercel-labs/agent-browser)
# Connect with: agent-browser connect 9222  OR  agent-browser --cdp 9222 snapshot
CDP_PORT=9222

# Hyperswarm P2P remote control
# Set SWARM_TOPIC to a shared secret string on both host and client machines to connect them
# Leave empty to disable P2P entirely
SWARM_TOPIC=

# Role: 'host' has the browser window and captures audio/screen
# Role: 'client' receives audio/screen and can send input/CDP commands
SWARM_ROLE=host

# Local WebSocket port for CDP proxy (agent-browser connects here on the client)
CDP_PROXY_PORT=9230
