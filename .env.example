DISCORD_BOT_TOKEN=your_bot_token_here
TARGET_URL=https://example.com
GUILD_ID=123456789012345678
CHANNEL_ID=123456789012345678
CDP_PORT=9229
# Any string — hashed to a 32-byte DHT topic. Must match on host and all clients.
SWARM_TOPIC=
# host: Electron app with TARGET_URL. client: Electron showing remote view (legacy).
# Headless CDP clients use node src/p2p/client.js instead (no Electron needed).
SWARM_ROLE=host
# Port for the local CDP WebSocket proxy (used by headless client and legacy client role).
CDP_PROXY_PORT=9230
WS_AUDIO_PORT=9888
