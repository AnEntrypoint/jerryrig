{
  "manifest_version": 3,
  "name": "Jerryrig Audio Bridge",
  "version": "1.0.0",
  "description": "Captures tab audio and sends PCM frames to Jerryrig via WebSocket",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jerryrig Audio Bridge"
  }
}
